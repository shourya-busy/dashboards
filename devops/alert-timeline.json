{
  "apiVersion": "dashboard.grafana.app/v2",
  "kind": "Dashboard",
  "metadata": {
    "name": "dcfq6gnik97280a"
  },
  "spec": {
    "annotations": [
      {
        "kind": "AnnotationQuery",
        "spec": {
          "builtIn": true,
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations \u0026 Alerts",
          "query": {
            "group": "grafana",
            "kind": "DataQuery",
            "spec": {},
            "version": "v0"
          }
        }
      }
    ],
    "cursorSync": "Crosshair",
    "description": "",
    "editable": true,
    "elements": {
      "panel-401": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Grafana-managed alerts currently firing or pending, filtered to the selected host(s). Shows each alert instance and how long it has been in state. Reads Grafana alerting directly (live).",
          "id": 401,
          "links": [],
          "title": "Firing Now - Current State (host-wise)",
          "vizConfig": {
            "group": "alertlist",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "alertInstanceLabelFilter": "{host=~\"$host\"}",
                "alertName": "",
                "dashboardAlerts": false,
                "groupBy": [],
                "groupMode": "default",
                "maxItems": 100,
                "showInactiveAlerts": false,
                "sortOrder": 3,
                "stateFilter": {
                  "error": true,
                  "firing": true,
                  "noData": false,
                  "normal": false,
                  "pending": true,
                  "recovering": true
                },
                "viewMode": "list"
              }
            },
            "version": "13.0.2"
          }
        }
      },
      "panel-402": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "spec": {
                        "editorMode": "code",
                        "expr": "max by (alertname, host, instance) (last_over_time({from=\"state-history\"} | json alertname=\"labels.alertname\", host=\"labels.host\", instance=\"labels.instance\", current=\"current\" | host=~\"$host\" | label_format sv=`{{ if eq .current \"Alerting\" }}3{{ else if eq .current \"Pending\" }}2{{ else if eq .current \"NoData\" }}4{{ else if eq .current \"Error\" }}5{{ else }}1{{ end }}` | unwrap sv [$__interval]))",
                        "legendFormat": "{{alertname}} {{host}}{{instance}}",
                        "queryType": "range"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Per-alert state over time, reconstructed from the Loki state-history stream. Each lane is one alert (x host where labelled); colour = state (red Alerting / yellow Pending / green Normal / purple NoData / orange Error). A bar's left edge is when that state began, the right edge when it changed. Hover for exact timestamps. Needs transitions to have been written since the Loki backend was enabled.",
          "id": 402,
          "links": [],
          "title": "Alert State Timeline (Loki, host-wise)",
          "vizConfig": {
            "group": "state-timeline",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {
                  "color": {
                    "mode": "thresholds"
                  },
                  "custom": {
                    "axisPlacement": "auto",
                    "fillOpacity": 85,
                    "hideFrom": {
                      "legend": false,
                      "tooltip": false,
                      "viz": false
                    },
                    "insertNulls": false,
                    "lineWidth": 0,
                    "spanNulls": true
                  },
                  "mappings": [
                    {
                      "options": {
                        "1": {
                          "color": "green",
                          "index": 0,
                          "text": "Normal"
                        },
                        "2": {
                          "color": "yellow",
                          "index": 1,
                          "text": "Pending"
                        },
                        "3": {
                          "color": "red",
                          "index": 2,
                          "text": "Alerting"
                        },
                        "4": {
                          "color": "purple",
                          "index": 3,
                          "text": "NoData"
                        },
                        "5": {
                          "color": "orange",
                          "index": 4,
                          "text": "Error"
                        }
                      },
                      "type": "value"
                    }
                  ],
                  "thresholds": {
                    "mode": "absolute",
                    "steps": [
                      {
                        "color": "green",
                        "value": 0
                      },
                      {
                        "color": "yellow",
                        "value": 2
                      },
                      {
                        "color": "red",
                        "value": 3
                      },
                      {
                        "color": "purple",
                        "value": 4
                      },
                      {
                        "color": "orange",
                        "value": 5
                      }
                    ]
                  }
                },
                "overrides": []
              },
              "options": {
                "alignValue": "left",
                "annotations": {
                  "clustering": -1,
                  "multiLane": false
                },
                "fillOpacity": 85,
                "legend": {
                  "displayMode": "list",
                  "placement": "bottom",
                  "showLegend": true
                },
                "mergeValues": true,
                "rowHeight": 0.9,
                "showValue": "auto",
                "tooltip": {
                  "hideZeros": false,
                  "mode": "single",
                  "sort": "none"
                }
              }
            },
            "version": "13.0.2"
          }
        }
      },
      "panel-403": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "group": "loki",
                      "kind": "DataQuery",
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "{from=\"state-history\"} | json alertname=\"labels.alertname\", host=\"labels.host\", instance=\"labels.instance\", current=\"current\", previous=\"previous\" | host=~\"$host\" | line_format \"{{.alertname}}  @ {{.host}}{{.instance}}  :  {{.previous}} -\u003e {{.current}}\"",
                        "queryType": "range"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "Raw Grafana alert state-change events from the Loki state-history stream, newest first. Each line is one transition with its exact timestamp - the reliable companion to the timeline above.",
          "id": 403,
          "links": [],
          "title": "Alert State Changes - Raw History (Loki)",
          "vizConfig": {
            "group": "logs",
            "kind": "VizConfig",
            "spec": {
              "fieldConfig": {
                "defaults": {},
                "overrides": []
              },
              "options": {
                "dedupStrategy": "none",
                "enableInfiniteScrolling": true,
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showControls": false,
                "showFieldSelector": false,
                "showLabels": false,
                "showLevel": false,
                "showTime": true,
                "sortOrder": "Descending",
                "timestampResolution": "ms",
                "unwrappedColumns": false,
                "wrapLogMessage": true
              }
            },
            "version": "13.0.2"
          }
        }
      }
    },
